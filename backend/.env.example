# MTA feeds are publicly accessible — no API key required.

# PostgreSQL connection string (leave as sqlite for local dev)
DB_URL=sqlite:///local.db

# Redis URL (leave blank to use in-memory fallback)
REDIS_URL=redis://localhost:6379/0

# Path to Firebase service account JSON (leave blank to skip auth)
# Download from Firebase Console → Project Settings → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=

# Flask secret key (any random string)
SECRET_KEY=change-me-in-production

# Poll interval for MTA feed in seconds
POLL_INTERVAL=30

# CORS origin for the frontend (Vite dev server)
CORS_ORIGIN=http://localhost:5173
